<DefaultWindow xmlns="https://spacestation14.io"
               Title="Z.A.X Linked Units"
               MinWidth="520"
               MinHeight="420"
               SetSize="520 420">
    <BoxContainer Orientation="Vertical" Margin="8">
        <BoxContainer Orientation="Horizontal" Margin="0 0 0 8">
            <Label Text="Linked Units"
                   HorizontalExpand="True" />
            <Button Name="RefreshButton"
                    Text="Refresh"
                    MinWidth="90" />
        </BoxContainer>

        <Label Name="EmptyLabel"
               Text="No active Z.A.X-linked units detected."
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               VerticalExpand="True" />

        <ScrollContainer HorizontalExpand="True"
                         VerticalExpand="True">
            <BoxContainer Name="UnitList"
                          Orientation="Vertical"
                          HorizontalExpand="True" />
        </ScrollContainer>
    </BoxContainer>
</DefaultWindow>
