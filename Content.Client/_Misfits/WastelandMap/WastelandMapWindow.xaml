<!-- #Misfits Change - Wasteland Map Viewer Window -->
<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      xmlns:viewport="clr-namespace:Content.Client.Viewport"
                      Title="Map"
                      Resizable="True"
                      SetSize="700 600"
                      MinSize="400 350">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">
        <!-- Map title header -->
        <controls:StripeBack>
            <PanelContainer>
                <Label Name="MapTitle" Text="Map" StyleClasses="LabelBig" Align="Center"/>
            </PanelContainer>
        </controls:StripeBack>

        <BoxContainer Name="ModeBar" Orientation="Horizontal" SeparationOverride="4" Margin="10 4 10 4" Visible="False">
            <Button Name="MapTabButton" Text="Map" MinWidth="80"/>
            <Button Name="OverwatchTabButton" Text="Overwatch" MinWidth="110"/>
        </BoxContainer>

        <BoxContainer Name="MapPanel" Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">
            <!-- Map image area - MapViewerControl added in code-behind -->
            <PanelContainer Name="MapContainer" HorizontalExpand="True" VerticalExpand="True"
                            StyleClasses="AngleRect"/>

            <!-- Footer -->
            <BoxContainer Name="FooterContainer" Orientation="Vertical">
                <PanelContainer StyleClasses="LowDivider"/>
                <BoxContainer Name="ToolbarContainer" Orientation="Vertical" Margin="10 4 10 0" VerticalAlignment="Bottom">
                    <BoxContainer Orientation="Horizontal" Margin="0 0 0 2">
                        <Button Name="PanModeButton" Text="Pan"/>
                        <Button Name="MarkerModeButton" Text="Marker" Margin="6 0 0 0"/>
                        <Button Name="BoxModeButton" Text="Box" Margin="6 0 0 0"/>
                        <Button Name="DrawModeButton" Text="Draw" Margin="6 0 0 0"/>
                        <Button Name="EraseButton" Text="Erase" Margin="6 0 0 0"/>
                        <Button Name="ClearMapButton" Text="Clear Map" Margin="6 0 0 0"/>
                        <LineEdit Name="AnnotationText" HorizontalExpand="True" Margin="8 0 0 0"
                                  PlaceHolder="Annotation text"/>
                    </BoxContainer>
                    <!-- Color swatches: populated in code-behind -->
                    <BoxContainer Name="ColorRow" Orientation="Horizontal" Margin="0 0 0 2" VerticalAlignment="Center"/>
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" Margin="10 2 5 0" VerticalAlignment="Bottom">
                    <Label Name="FooterText" Text="Scroll to zoom | Click and drag to pan | Right click an annotation to delete it"
                           StyleClasses="WindowFooterText"
                           HorizontalAlignment="Left" HorizontalExpand="True" Margin="0 0 5 0"/>
                </BoxContainer>
            </BoxContainer>
        </BoxContainer>

        <BoxContainer Name="OverwatchPanel" Orientation="Vertical" VerticalExpand="True" SeparationOverride="4" Visible="False" Margin="10 4 10 8">
            <BoxContainer Orientation="Horizontal" SeparationOverride="8" HorizontalExpand="True">
                <Label Name="OverwatchHeaderLabel" Text="PERSONNEL MONITOR" StyleClasses="monospace" HorizontalExpand="True" />
                <Label Name="OverwatchSignalLabel" Text="UPLINK READY" StyleClasses="monospace" HorizontalAlignment="Right" />
            </BoxContainer>
            <PanelContainer Name="SepOverwatch" MinHeight="1" HorizontalExpand="True" />
            <BoxContainer Orientation="Horizontal" VerticalExpand="True" SeparationOverride="8">
                <BoxContainer Orientation="Vertical" MinWidth="300" MaxWidth="380" SeparationOverride="4">
                    <RichTextLabel Name="OverwatchRosterSummaryLabel" StyleClasses="monospace" HorizontalExpand="True" />
                    <LineEdit Name="OverwatchSearchBar" PlaceHolder="Search linked personnel..." HorizontalExpand="True" />
                    <Label Name="OverwatchNoPersonnelLabel" Text="No eligible personnel found." StyleClasses="monospace" />
                    <ScrollContainer VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                        <BoxContainer Name="OverwatchPersonnelList" Orientation="Vertical" SeparationOverride="6" HorizontalExpand="True" />
                    </ScrollContainer>
                </BoxContainer>

                <PanelContainer MinWidth="1" VerticalExpand="True" />

                <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True" SeparationOverride="6">
                    <Button Name="OverwatchStopWatchingButton" Text="Stop Watch" HorizontalAlignment="Left" MinWidth="120" />
                    <LayoutContainer Name="OverwatchCameraViewBox" MinSize="320 220" HorizontalExpand="True" VerticalExpand="True">
                        <viewport:ScalingViewport Name="OverwatchCameraView" VerticalExpand="True" HorizontalExpand="True" MouseFilter="Ignore" />
                        <PanelContainer Name="OverwatchCameraFallback" VerticalExpand="True" HorizontalExpand="True">
                            <Label Name="OverwatchCameraFallbackLabel" Text="NO ACTIVE CAMERA FEED" StyleClasses="monospace" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </PanelContainer>
                    </LayoutContainer>
                    <RichTextLabel Name="OverwatchStatusLabel" StyleClasses="monospace" HorizontalExpand="True" />
                </BoxContainer>
            </BoxContainer>
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
